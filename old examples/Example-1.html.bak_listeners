<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aura — Premium Spaced Repetition</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,600;1,400&display=swap" rel="stylesheet">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --bg-dark: #09090b;
            --bg-card: #121214;
            --bg-card-hover: #1a1a1e;
            --border: rgba(255, 255, 255, 0.08);
            --text-primary: #f4f4f5;
            --text-secondary: #a1a1aa;
            --text-muted: #52525b;
            
            /* Premium Accent Palette */
            --accent: #d4af37; /* Matte Gold */
            --accent-glow: rgba(212, 175, 55, 0.15);
            --success: #10b981;
            --error: #ef4444;
            
            /* HLR Decay / Health colors */
            --health-high: #34d399;
            --health-mid: #fbbf24;
            --health-low: #f87171;

            --font-sans: 'Plus Jakarta Sans', sans-serif;
            --font-serif: 'Playfair Display', serif;
            
            --transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-primary);
            font-family: var(--font-sans);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow-x: hidden;
            padding: 2rem 1rem;
        }

        /* App Container */
        .app-container {
            width: 100%;
            max-width: 480px;
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        /* Header / Dashboard Metrics */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--border);
        }

        .brand {
            font-family: var(--font-serif);
            font-size: 1.5rem;
            font-weight: 600;
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, #fff 0%, var(--text-secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .metrics {
            display: flex;
            gap: 1rem;
            font-size: 0.9rem;
            font-weight: 600;
        }

        .metric-badge {
            background: var(--bg-card);
            border: 1px solid var(--border);
            padding: 0.5rem 0.75rem;
            border-radius: 99px;
            display: flex;
            align-items: center;
            gap: 0.35rem;
            color: var(--text-secondary);
        }
        
        .metric-badge.active i {
            color: var(--accent);
            filter: drop-shadow(0 0 4px var(--accent));
        }

        /* Global Smart Session Status Bar (Duolingo Style Progression) */
        .session-progress-container {
            width: 100%;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .progress-bar-track {
            flex: 1;
            height: 6px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 99px;
            overflow: hidden;
            position: relative;
        }

        .progress-bar-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--accent) 0%, #f3e5ab 100%);
            border-radius: 99px;
            transition: var(--transition);
            box-shadow: 0 0 12px var(--accent-glow);
        }

        /* Lexeme / Vocabulary Dashboard Grid */
        .dashboard-view {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .section-title {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-muted);
            font-weight: 700;
            margin-bottom: 0.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .smart-cta {
            background: linear-gradient(135deg, var(--bg-card) 0%, rgba(20,20,22,1) 100%);
            border: 1px solid var(--border);
            padding: 1.75rem;
            border-radius: 24px;
            text-align: center;
            position: relative;
            overflow: hidden;
            cursor: pointer;
            transition: var(--transition);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .smart-cta::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: radial-gradient(circle at top right, var(--accent-glow), transparent 60%);
            pointer-events: none;
        }

        .smart-cta:hover {
            transform: translateY(-2px);
            border-color: rgba(212, 175, 55, 0.3);
        }

        .smart-cta h3 {
            font-family: var(--font-serif);
            font-size: 1.4rem;
            margin-bottom: 0.5rem;
        }

        .smart-cta p {
            color: var(--text-secondary);
            font-size: 0.9rem;
            margin-bottom: 1.25rem;
            line-height: 1.4;
        }

        .btn-premium {
            background: var(--text-primary);
            color: var(--bg-dark);
            border: none;
            padding: 0.85rem 1.75rem;
            border-radius: 14px;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            font-family: var(--font-sans);
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
        }

        .btn-premium:hover {
            background: #fff;
            transform: scale(1.02);
            box-shadow: 0 4px 20px rgba(255,255,255,0.15);
        }

        /* Interactive Concept Injection Form */
        .creator-panel {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 1.25rem;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .form-row {
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
        }

        .form-row label {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .form-row input, .form-row textarea {
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 0.65rem 0.85rem;
            color: var(--text-primary);
            font-family: var(--font-sans);
            font-size: 0.9rem;
            transition: var(--transition);
        }

        .form-row input:focus, .form-row textarea:focus {
            outline: none;
            border-color: var(--accent);
            background: rgba(0, 0, 0, 0.4);
        }

        .form-row textarea {
            resize: none;
            height: 60px;
        }

        .btn-secondary {
            background: rgba(255, 255, 255, 0.04);
            color: var(--text-primary);
            border: 1px solid var(--border);
            padding: 0.65rem;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            transition: var(--transition);
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: var(--text-secondary);
        }

        /* Lexeme Registry List */
        .lexeme-list {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            max-height: 400px;
            overflow-y: auto;
            padding-right: 0.25rem;
        }

        .lexeme-list::-webkit-scrollbar {
            width: 4px;
        }
        .lexeme-list::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 99px;
        }

        .lexeme-row {
            background: var(--bg-card);
            border: 1px solid var(--border);
            padding: 1rem 1.25rem;
            border-radius: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: var(--transition);
        }

        .lexeme-info {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            max-width: 65%;
        }

        .lexeme-word {
            font-weight: 600;
            font-size: 1.05rem;
            letter-spacing: -0.01em;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .lexeme-translation {
            font-size: 0.85rem;
            color: var(--text-secondary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .lexeme-status {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 0.4rem;
            width: 100px;
        }

        .half-life-text {
            font-size: 0.75rem;
            font-weight: 500;
            color: var(--text-muted);
        }

        .health-bar-track {
            width: 100%;
            height: 4px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 99px;
            overflow: hidden;
        }

        .health-bar-fill {
            height: 100%;
            border-radius: 99px;
            transition: width 0.5s ease;
        }

        /* Core Flashcard Interface (Stage View) */
        .stage-view {
            display: none; /* Managed by JS switching */
            flex-direction: column;
            gap: 2rem;
            perspective: 1000px;
        }

        .card-perspective {
            width: 100%;
            height: 340px;
            cursor: pointer;
            position: relative;
        }

        .flashcard {
            width: 100%;
            height: 100%;
            position: absolute;
            transform-style: preserve-3d;
            transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border-radius: 32px;
        }

        .flashcard.flipped {
            transform: rotateY(180deg);
        }

        .card-face {
            position: absolute;
            width: 100%;
            height: 100%;
            backface-visibility: hidden;
            border-radius: 32px;
            border: 1px solid var(--border);
            padding: 2.5rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
        }

        .card-front {
            background: linear-gradient(145deg, var(--bg-card) 0%, #16161a 100%);
        }

        .card-back {
            background: linear-gradient(145deg, #131317 0%, var(--bg-dark) 100%);
            transform: rotateY(180deg);
        }

        .card-meta-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
        }

        .card-main-content {
            text-align: center;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            justify-content: center;
            flex: 1;
        }

        .prompt-word {
            font-family: var(--font-serif);
            font-size: 2.2rem;
            font-weight: 500;
            letter-spacing: -0.02em;
            line-height: 1.2;
        }

        .prompt-context {
            font-size: 0.95rem;
            color: var(--text-secondary);
            font-style: italic;
            line-height: 1.4;
            max-width: 90%;
            margin: 0 auto;
        }

        .reveal-hint-text {
            font-size: 0.8rem;
            color: var(--accent);
            font-weight: 500;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.25rem;
            opacity: 0.7;
        }

        /* Input Controls Room (Evaluative Engine) */
        .interaction-panel {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .eval-buttons {
            display: none; /* Visible only when card flipped */
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            width: 100%;
        }

        .btn-action {
            padding: 1.1rem;
            border-radius: 16px;
            font-family: var(--font-sans);
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            transition: var(--transition);
            background: var(--bg-card);
            border: 1px solid var(--border);
            color: var(--text-primary);
        }

        .btn-action[data-status="wrong"] {
            border-color: rgba(239, 68, 110, 0.2);
        }
        .btn-action[data-status="wrong"]:hover {
            background: rgba(239, 68, 68, 0.1);
            border-color: var(--error);
            color: var(--error);
        }

        .btn-action[data-status="correct"] {
            border-color: rgba(16, 185, 129, 0.2);
        }
        .btn-action[data-status="correct"]:hover {
            background: rgba(16, 185, 129, 0.1);
            border-color: var(--success);
            color: var(--success);
        }

        .hint-disclosure {
            background: rgba(255, 255, 255, 0.02);
            border: 1px dashed var(--border);
            border-radius: 14px;
            padding: 0.85rem 1rem;
            font-size: 0.85rem;
            color: var(--text-secondary);
            display: none;
            align-items: center;
            gap: 0.5rem;
            line-height: 1.4;
        }

        .hint-disclosure i {
            color: var(--accent);
            flex-shrink: 0;
        }

        /* Utilities */
        .hidden { display: none !important; }
        .flex { display: flex !important; }

        /* Smooth subtle keyframe entries */
        @keyframes subtleScale {
            from { transform: scale(0.98); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }
        .animate-fade-in {
            animation: subtleScale 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
    </style>
</head>
<body>

    <div class="app-container">
        <!-- Persistent Premium Status Bar -->
        <header>
            <div class="brand">
                <span>AURA</span>
            </div>
            <div class="metrics">
                <div class="metric-badge active" title="Current Daily Streak">
                    <i data-lucide="zap"></i>
                    <span id="streak-count">6</span>
                </div>
                <div class="metric-badge" title="Total Retained Items">
                    <i data-lucide="layers"></i>
                    <span id="retained-count">0</span>
                </div>
            </div>
        </header>

        <!-- Contextual HLR Progress Module -->
        <div class="session-progress-container" id="session-progress-wrapper">
            <button class="btn-action" id="exit-session-btn" style="padding: 0.4rem; border-radius: 50%; width: 32px; height: 32px;" title="Exit Session">
                <i data-lucide="x" style="width: 16px; height: 16px;"></i>
            </button>
            <div class="progress-bar-track">
                <div class="progress-bar-fill" id="session-progress"></div>
            </div>
        </div>

        <!-- VIEW 1: PREMIUM USER DASHBOARD -->
        <div id="dashboard-view" class="dashboard-view animate-fade-in">
            <div class="smart-cta" id="start-srs-session">
                <h3>Personalized Practice</h3>
                <p>Our Half-Life Regression model indicates <strong><span id="decayed-count-prompt">0</span> concepts</strong> are approaching their memory critical dip threshold.</p>
                <button class="btn-premium">
                    <i data-lucide="sparkles"></i> Begin Review
                </button>
            </div>

            <!-- New Real-Time Ingestion Form -->
            <div class="creator-panel">
                <h4 style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent); margin-bottom: 0.25rem;">Quick-Add Flashcard</h4>
                <form id="concept-creator-form" onsubmit="handleFormSubmission(event)">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 0.75rem;">
                        <div class="form-row">
                            <label for="form-word">Concept / Target</label>
                            <input type="text" id="form-word" placeholder="e.g., Confirmation Bias" required>
                        </div>
                        <div class="form-row">
                            <label for="form-translation">Definition / Core Meaning</label>
                            <input type="text" id="form-translation" placeholder="e.g., Favoring matching data" required>
                        </div>
                    </div>
                    <div class="form-row" style="margin-bottom: 0.75rem;">
                        <label for="form-context">Context Clue / Application</label>
                        <textarea id="form-context" placeholder="How is this concept applied or used in a sentence?"></textarea>
                    </div>
                    <div class="form-row" style="margin-bottom: 1rem;">
                        <label for="form-hint">Passive Hint Clue</label>
                        <input type="text" id="form-hint" placeholder="A trigger phrase or subtle identifier">
                    </div>
                    <button type="submit" class="btn-secondary" style="width: 100%;">
                        <i data-lucide="plus-circle" style="width: 16px;"></i> Commit to Matrix
                    </button>
                </form>
            </div>

            <div>
                <h4 class="section-title">Knowledge Registry (SRS Status)</h4>
                <div class="lexeme-list" id="lexeme-container">
                    <!-- Dynamic Rows Rendered by JS Engine -->
                </div>
            </div>
        </div>

        <!-- VIEW 2: SRS COGNITIVE STAGE (FLASHCARD CORE) -->
        <div id="stage-view" class="stage-view">
            <div class="card-perspective" id="card-trigger">
                <div class="flashcard" id="interactive-card">
                    
                    <!-- Front Face -->
                    <div class="card-face card-front">
                        <div class="card-meta-top">
                            <span id="card-category-front">Active Concept</span>
                            <div id="card-health-indicator-front" style="display: flex; align-items:center; gap:4px;">
                                <div style="width:8px; height:8px; border-radius:50%;" id="health-dot"></div>
                            </div>
                        </div>
                        <div class="card-main-content">
                            <span class="prompt-word" id="word-front">--</span>
                            <p class="prompt-context" id="context-front">--</p>
                        </div>
                        <div class="reveal-hint-text">
                            <i data-lucide="rotate-cw" style="width: 14px; height:14px;"></i> Tap card to flip and evaluate
                        </div>
                    </div>

                    <!-- Back Face -->
                    <div class="card-face card-back">
                        <div class="card-meta-top">
                            <span>Target Definition</span>
                            <i data-lucide="check-circle-2" style="width: 14px; color: var(--text-muted)"></i>
                        </div>
                        <div class="card-main-content">
                            <span class="prompt-word" id="word-back" style="color: var(--accent)">--</span>
                            <p class="prompt-context" id="context-back">--</p>
                        </div>
                        <div style="height: 14px;"></div> <!-- Spacer matching front layout structure -->
                    </div>

                </div>
            </div>

            <!-- Interaction Mechanics Footer -->
            <div class="interaction-panel">
                <div class="hint-disclosure" id="hint-panel">
                    <i data-lucide="help-circle"></i>
                    <span id="hint-text"></span>
                </div>
                
                <!-- Prompt Toggle Mode Box -->
                <button class="btn-action" id="request-hint-btn" style="font-size: 0.85rem; color: var(--text-secondary);">
                    <i data-lucide="eye" style="width:16px;"></i> Reveal Passive Hint
                </button>

                <!-- Spaced Repetition Algorithmic Evaluations Hooks -->
                <div class="eval-buttons" id="eval-actions-wrapper">
                    <button class="btn-action" data-status="wrong" id="btn-eval-wrong">
                        <i data-lucide="x-circle"></i> Forgot / Miscalculated
                    </button>
                    <button class="btn-action" data-status="correct" id="btn-eval-correct">
                        <i data-lucide="check-circle"></i> Retained Cleanly
                    </button>
                </div>
            </div>
        </div>

    </div>

    <!-- App Engine -->
    <script>
        /**
         * Aura Spaced Repetition Engine
         * Upgraded with dynamic Spacing Multipliers and Soft-Landing Penalties
         */

        // Standard Universal Baseline Concepts Seeding
        const INITIAL_LEXEMES = [
            { id: 'l1', word: 'Cognitive Dissonance', translation: 'Psychological discomfort from holding conflicting beliefs.', context: 'Experiencing tension when actions don\'t align with core morals.', hint: 'Internal harmony friction.', halfLifeHours: 12, lastTested: Date.now() - (14 * 60 * 60 * 1000) },
            { id: 'l2', word: 'Pareto Principle', translation: 'The 80/20 rule optimization strategy.', context: '80% of systemic consequences derive directly from 20% of core causes.', hint: 'Focusing resources on the vital vital few.', halfLifeHours: 48, lastTested: Date.now() - (52 * 60 * 60 * 1000) },
            { id: 'l3', word: 'Occam\'s Razor', translation: 'The simplest explanation with the fewest assumptions is usually best.', context: 'When analyzing competing hypotheses, avoid overcomplicating variables.', hint: 'Shaving away unnecessary logical fluff.', halfLifeHours: 120, lastTested: Date.now() - (10 * 60 * 60 * 1000) },
            { id: 'l4', word: 'Neuroplasticity', translation: 'The brain\'s capacity to reorganize structural pathways.', context: 'Synaptic patterns shifting actively via deep repetitive learning engagement.', hint: 'Malleable and dynamic cognitive architecture.', halfLifeHours: 24, lastTested: Date.now() - (26 * 60 * 60 * 1000) }
        ];

        // System State Setup
        let lexemes = JSON.parse(localStorage.getItem('aura_lexemes')) || INITIAL_LEXEMES;
        let activeSessionQueue = [];
        let totalQueueLength = 0;
        let currentActiveIndex = 0;
        let hintRequestedForCurrentCard = false;

        const views = {
            dashboard: document.getElementById('dashboard-view'),
            stage: document.getElementById('stage-view'),
            progressWrapper: document.getElementById('session-progress-wrapper')
        };

        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
            calculateAndRenderDashboard();
            setupEventListeners();
        });

        function saveToStorage() {
            localStorage.setItem('aura_lexemes', JSON.stringify(lexemes));
        }

        /**
         * Standardized programmatic factory invocation layer
         * Drops card straight into immediate decay loop for instant exposure setup
         */
        function addLexeme(word, translation, context = '', hint = '') {
            const newCard = {
                id: 'l_' + Date.now() + Math.random().toString(36).substr(2, 4),
                word: (word || '').trim(),
                translation: (translation || '').trim(),
                context: (context || '').trim() || 'No application context provided.',
                hint: (hint || '').trim() || 'No specialized hints setup.',
                halfLifeHours: 4, 
                lastTested: Date.now() - (6 * 60 * 60 * 1000) // Forces card into immediate upcoming review array
            };

            lexemes.push(newCard);
            saveToStorage();
            calculateAndRenderDashboard();
            return newCard;
        }

        /**
         * Interface wrapper hooked into the HTML Creator layout block
         */
        function handleFormSubmission(event) {
            event.preventDefault();
            
            const wordInput = document.getElementById('form-word');
            const translationInput = document.getElementById('form-translation');
            const contextInput = document.getElementById('form-context');
            const hintInput = document.getElementById('form-hint');

            addLexeme(wordInput.value, translationInput.value, contextInput.value, hintInput.value);
            
            // Clean visual state reset cleanly
            event.target.reset();
        }

        /**
         * Core Mathematical Logic - Half-Life Regression Engine
         * Probability of Retention: P = 2^(-t / h)
         */
        function calculateRetention(lexeme) {
            const elapsedHours = (Date.now() - lexeme.lastTested) / (1000 * 60 * 60);
            const retentionProbability = Math.pow(2, -elapsedHours / lexeme.halfLifeHours);
            return Math.min(Math.max(retentionProbability, 0.0), 1.0);
        }

        function calculateAndRenderDashboard() {
            const container = document.getElementById('lexeme-container');
            container.innerHTML = '';
            let decayedCount = 0;
            let healthyCount = 0;

            lexemes.forEach(item => {
                const retention = calculateRetention(item);
                const percentage = Math.round(retention * 100);
                
                let healthColor = varLookUp('--health-high');
                if (retention < 0.5) {
                    decayedCount++;
                    healthColor = varLookUp('--health-low');
                } else if (retention < 0.75) {
                    healthColor = varLookUp('--health-mid');
                } else {
                    healthyCount++;
                }

                const row = document.createElement('div');
                row.className = 'lexeme-row';
                row.innerHTML = `
                    <div class="lexeme-info">
                        <span class="lexeme-word">${item.word}</span>
                        <span class="lexeme-translation">${item.translation}</span>
                    </div>
                    <div class="lexeme-status">
                        <span class="half-life-text">${percentage}% Recall</span>
                        <div class="health-bar-track">
                            <div class="health-bar-fill" style="width: ${percentage}%; background-color: ${healthColor};"></div>
                        </div>
                    </div>
                `;
                container.appendChild(row);
            });

            const ctaParagraph = document.querySelector('#start-srs-session p');
            if (decayedCount === 0) {
                if (ctaParagraph) ctaParagraph.innerText = 'All matrix fields are mathematically safe and stable.';
            } else {
                if (ctaParagraph) ctaParagraph.innerHTML = `Our Half-Life Regression model indicates <strong><span id="decayed-count-prompt">${decayedCount}</span> concepts</strong> are approaching their memory critical dip threshold.`;
            }

            const retainedEl = document.getElementById('retained-count');
            if (retainedEl) retainedEl.innerText = healthyCount;

            views.progressWrapper.style.visibility = 'hidden';
        }

        function varLookUp(variableName) {
            return getComputedStyle(document.documentElement).getPropertyValue(variableName).trim();
        }

        function setupEventListeners() {
            document.getElementById('start-srs-session').addEventListener('click', initiateSRSSession);
            document.getElementById('exit-session-btn').addEventListener('click', exitSessionView);
            document.getElementById('card-trigger').addEventListener('click', toggleCardFlip);
            document.getElementById('request-hint-btn').addEventListener('click', revealPassiveHint);

            document.getElementById('btn-eval-correct').addEventListener('click', () => handleEvaluationOutcome(true));
            document.getElementById('btn-eval-wrong').addEventListener('click', () => handleEvaluationOutcome(false));
        }

        function initiateSRSSession() {
            let candidates = lexemes.filter(item => calculateRetention(item) < 0.95);

            if (candidates.length === 0) {
                candidates = [...lexemes];
            }

            activeSessionQueue = candidates.sort((a, b) => calculateRetention(a) - calculateRetention(b));
            activeSessionQueue = activeSessionQueue.slice(0, 5);
            totalQueueLength = activeSessionQueue.length;
            currentActiveIndex = 0;

            if (totalQueueLength === 0) return;

            views.dashboard.style.display = 'none';
            views.stage.style.display = 'flex';
            views.progressWrapper.style.visibility = 'visible';

            renderCurrentSessionCard();
            updateProgressBar();
        }

        function renderCurrentSessionCard() {
            if (currentActiveIndex >= totalQueueLength) {
                completeSessionView();
                return;
            }

            hintRequestedForCurrentCard = false;
            document.getElementById('hint-panel').style.display = 'none';
            document.getElementById('request-hint-btn').style.display = 'inline-flex';
            document.getElementById('eval-actions-wrapper').style.display = 'none';
            document.getElementById('interactive-card').classList.remove('flipped');

            const item = activeSessionQueue[currentActiveIndex];
            const retention = calculateRetention(item);

            document.getElementById('word-front').innerText = item.word;
            document.getElementById('context-front').innerText = item.context;
            document.getElementById('word-back').innerText = item.translation;
            document.getElementById('context-back').innerText = item.context;
            document.getElementById('hint-text').innerText = item.hint;

            const healthDot = document.getElementById('health-dot');
            if (retention < 0.5) healthDot.style.backgroundColor = varLookUp('--health-low');
            else if (retention < 0.75) healthDot.style.backgroundColor = varLookUp('--health-mid');
            else healthDot.style.backgroundColor = varLookUp('--health-high');
        }

        function toggleCardFlip() {
            const card = document.getElementById('interactive-card');
            card.classList.toggle('flipped');
            
            const isFlipped = card.classList.contains('flipped');
            if (isFlipped) {
                document.getElementById('eval-actions-wrapper').style.display = 'grid';
                document.getElementById('request-hint-btn').style.display = 'none';
            }
        }

        function revealPassiveHint() {
            hintRequestedForCurrentCard = true;
            document.getElementById('hint-panel').style.display = 'flex';
            document.getElementById('request-hint-btn').style.display = 'none';
        }

        function handleEvaluationOutcome(isCorrect) {
            const currentItem = activeSessionQueue[currentActiveIndex];
            const matchedLexeme = lexemes.find(l => l.id === currentItem.id);

            if (matchedLexeme) {
                if (isCorrect) {
                    const elapsedHours = (Date.now() - matchedLexeme.lastTested) / (1000 * 60 * 60);
                    
                    // Dynamic Spacing adjustments based on system stability states
                    let adaptiveMultiplier = matchedLexeme.halfLifeHours < 48 ? 2.5 : 1.6;

                    if (hintRequestedForCurrentCard) {
                        adaptiveMultiplier *= 0.6; // Scale down expansion value if hint was vital
                    }

                    const computedExtension = Math.max(elapsedHours, matchedLexeme.halfLifeHours) * adaptiveMultiplier;
                    matchedLexeme.halfLifeHours = Math.min(computedExtension, 720); // 30-day ceiling boundary limit
                } else {
                    // Optimized Soft-Landing Penalty
                    if (matchedLexeme.halfLifeHours > 72) {
                        matchedLexeme.halfLifeHours = matchedLexeme.halfLifeHours * 0.5; // Cushioned drop for historical assets
                    } else {
                        matchedLexeme.halfLifeHours = Math.max(matchedLexeme.halfLifeHours * 0.25, 4); // Volatile cards reset near baseline floor
                    }
                }

                matchedLexeme.lastTested = Date.now();
                saveToStorage();
            }

            currentActiveIndex++;
            updateProgressBar();
            
            setTimeout(() => {
                renderCurrentSessionCard();
            }, 300);
        }

        function updateProgressBar() {
            const ratio = (currentActiveIndex / totalQueueLength) * 100;
            document.getElementById('session-progress').style.width = `${ratio}%`;
        }

        function completeSessionView() {
            exitSessionView();
            const streakElement = document.getElementById('streak-count');
            streakElement.innerText = parseInt(streakElement.innerText) + 1;
        }

        function exitSessionView() {
            views.stage.style.display = 'none';
            views.dashboard.style.display = 'flex';
            calculateAndRenderDashboard();
        }
    </script>
</body>
